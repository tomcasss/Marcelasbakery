# ===================================
# VARIABLES DE ENTORNO - LA GRACIA
# ===================================

# ==========================================
# FRONTEND (Vite - prefijo VITE_)
# ==========================================

# Stripe Publishable Key (empieza con pk_)
# Obtener de: https://dashboard.stripe.com/apikeys
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_TuClaveAqui

# URL del backend API
VITE_API_URL=http://localhost:3001

# ==========================================
# BACKEND (Node.js + Express)
# ==========================================

# Puerto del servidor
PORT=3001

# Stripe Secret Key (empieza con sk_)
# ⚠️ NUNCA exponer esta clave en el frontend
STRIPE_SECRET_KEY=sk_test_TuClaveSecretaAqui

# Stripe Webhook Secret (empieza con whsec_)
# Se obtiene al configurar webhooks en Stripe
STRIPE_WEBHOOK_SECRET=whsec_TuSecretoWebhookAqui

# ==========================================
# BASE DE DATOS
# ==========================================

# MongoDB (opción recomendada)
DATABASE_URL=mongodb://localhost:27017/lagracia
# o MongoDB Atlas:
# DATABASE_URL=mongodb+srv://usuario:password@cluster.mongodb.net/lagracia

# PostgreSQL (alternativa)
# DATABASE_URL=postgresql://usuario:password@localhost:5432/lagracia

# ==========================================
# EMAIL (Gmail)
# ==========================================

# Email desde donde se envían los correos
EMAIL_USER=marcelasbakery@gmail.com

# App Password de Gmail (NO usar contraseña normal)
# Generar en: https://myaccount.google.com/apppasswords
EMAIL_PASS=tu_password_de_app_aqui

# SMTP Host (para Gmail)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587

# ==========================================
# WHATSAPP (OPCIONAL)
# ==========================================

# Twilio para WhatsApp Business API
TWILIO_ACCOUNT_SID=tu_account_sid
TWILIO_AUTH_TOKEN=tu_auth_token
TWILIO_WHATSAPP_NUMBER=+14155238886

# ==========================================
# SEGURIDAD
# ==========================================

# JWT Secret para autenticación admin
JWT_SECRET=tu_secreto_super_seguro_aqui

# Origenes permitidos para CORS (separados por coma)
CORS_ORIGINS=http://localhost:5173,https://tudominio.com

# ==========================================
# OTROS
# ==========================================

# Entorno (development, production)
NODE_ENV=development

# URL del frontend (para redirecciones)
FRONTEND_URL=http://localhost:5173
