# Copia este archivo a .env y completa los valores

# Puerto del servidor
PORT=3001

# MongoDB Atlas (gratis): https://www.mongodb.com/cloud/atlas
# Crear cluster gratis → Connect → Driver → copiar connection string
MONGODB_URI=mongodb+srv://usuario:password@cluster0.xxxxx.mongodb.net/lagracia?retryWrites=true&w=majority

# Gmail para enviar emails (gratis)
# Crear "Contraseña de aplicación" en: https://myaccount.google.com/apppasswords
EMAIL_USER=marcelasbakery@gmail.com
EMAIL_PASS=tu_contraseña_de_aplicacion

# URL del frontend (para CORS). En producción: https://tudominio.com
FRONTEND_URL=http://localhost:5173
